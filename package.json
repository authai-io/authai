{
  "name": "ai-connect",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm -r --parallel --filter './packages/*' --filter './apps/example-react' dev",
    "dev:relay": "pnpm --filter @ai-connect/relay dev",
    "dev:example": "pnpm --filter @ai-connect/example-react dev",
    "build": "pnpm -r build"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
