{
  "name": "@authai-io/relay",
  "version": "0.1.0",
  "description": "AuthAI relay core — Hono app that runs the OAuth device-code flow, encrypts tokens, and proxies OpenAI-compatible model calls.",
  "homepage": "https://authai.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/authai-io/authai.git",
    "directory": "packages/relay"
  },
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "pnpm build && node ../../scripts/prepack.mjs",
    "postpack": "node ../../scripts/postpack.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.12",
    "jose": "^5.9.6",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
