{
  "name": "@authai-io/server",
  "version": "0.1.0",
  "description": "AuthAI server SDK — authai.session() and decodeAuthAIToken() for verifying AuthAI JWTs in your backend.",
  "homepage": "https://authai.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/authai-io/authai.git",
    "directory": "packages/server"
  },
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "prepack": "pnpm build && node ../../scripts/prepack.mjs",
    "postpack": "node ../../scripts/postpack.mjs"
  },
  "dependencies": {
    "jose": "^5.9.6"
  },
  "peerDependencies": {
    "openai": ">=4"
  },
  "peerDependenciesMeta": {
    "openai": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "openai": "^4.77.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
