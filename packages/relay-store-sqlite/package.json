{
  "name": "@authai-io/relay-store-sqlite",
  "version": "0.1.0",
  "description": "SQLite storage driver for the AuthAI relay. Single-file persistence for self-hosted single-instance deploys.",
  "homepage": "https://authai.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/authai-io/authai.git",
    "directory": "packages/relay-store-sqlite"
  },
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "prepack": "pnpm build && node ../../scripts/prepack.mjs",
    "postpack": "node ../../scripts/postpack.mjs"
  },
  "dependencies": {
    "@authai-io/relay": "workspace:*",
    "better-sqlite3": "^11.6.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
